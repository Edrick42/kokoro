# Kokoro API — Environment Variables
# Copy to .env and fill in your values.

# Stripe (get from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_your_key_here

# Shop redirect URLs (after Stripe checkout)
SHOP_SUCCESS_URL=http://localhost:3000/profile?purchase=success
SHOP_CANCEL_URL=http://localhost:3000/profile?purchase=cancelled

# Donation redirect URLs
DONATE_SUCCESS_URL=http://localhost:3000/?donated=true
DONATE_CANCEL_URL=http://localhost:3000/

# CORS — comma-separated allowed origins (restrictive in production)
ALLOWED_ORIGINS=http://localhost:3000
